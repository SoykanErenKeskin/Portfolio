# Supabase - create project at https://supabase.com
# Run supabase/migrations/001_init.sql in SQL Editor, then: npm run db:seed


# NextAuth - generate with: npx auth secret
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Admin - for initial setup (run: npm run db:seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# DeepL - TR→EN translation in admin project form (optional)
# Free key: https://www.deepl.com/pro-api → 500K chars/month
DEEPL_API_KEY=""

# Chatbot – use one of:
# OpenRouter (recommended, free tier): https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="stepfun/step-3.5-flash:free"  # default
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
